<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/manager_navigation"
    app:startDestination="@id/navigation_manager">

    <fragment
        android:id="@+id/navigation_manager"
        android:name="cc.meteormc.yourmiui.ui.fragment.ManagerFragment"
        android:label="manager"
        tools:layout="@layout/fragment_manager">

        <action
            android:id="@+id/action_manager_to_scope"
            app:destination="@id/navigation_scope"
            app:enterAnim="@anim/scale_in_expand"
            app:exitAnim="@anim/scale_out_expand"
            app:popEnterAnim="@anim/scale_in_shrink"
            app:popExitAnim="@anim/scale_out_shrink" />

    </fragment>

    <fragment
        android:id="@+id/navigation_scope"
        android:name="cc.meteormc.yourmiui.ui.fragment.ScopeFragment"
        android:label="scope"
        tools:layout="@layout/fragment_scope" />

</navigation>